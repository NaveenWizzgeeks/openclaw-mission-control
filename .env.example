# Mission Control v2 — environment

# MongoDB (required — task store)
# Local default: mongodb://127.0.0.1:27017
# Atlas: mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true
MONGODB_URI=mongodb://127.0.0.1:27017

# Telegram bridge (optional — only needed if you want Telegram task ingest)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenClaw gateway (defaults shown)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_ORIGIN=http://localhost:3000

# Operator bearer token (required for non-localhost gateways).
# v2: SERVER-SIDE only — never expose as NEXT_PUBLIC_*.
OPENCLAW_TOKEN=

# Daemon HTTP bind (defaults shown — change if 18790 conflicts)
MC_DAEMON_HOST=127.0.0.1
MC_DAEMON_PORT=18790

# Daemon log level: debug | info | warn | error
MC_LOG_LEVEL=info
