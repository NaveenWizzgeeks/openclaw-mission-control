{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "types": ["node"],
    "isolatedModules": false
  },
  "include": ["src/daemon/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
